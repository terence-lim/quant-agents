def load_pivot_csv(
    values: str,
    index: str,
    columns: str,
    sep: str,
    filename: str | Path,
    keep: List = [],
) -> pd.DataFrame:
    """Helper to read from CSV file and pivot to columns"""
    df = pd.read_csv(filename, sep=sep, header=0, low_memory=False)
    df = df.pivot(index=index, columns=columns, values=values).sort_index()
    if keep:
        df = df[keep]
    df = df.convert_dtypes()
    df.index.name = DATE_NAME
    return df


def load_jkp(
    benchmarks_path: str = BENCHMARKS_DIR / "USA.csv",
    definitions_path: str = DATA_LAKE / "JKP.csv",
    data_folder: str = DATA_LAKE / "USA",
    RAG_PATH: str = JKP_RAG_PATH,
    build_characteristics: bool = True,
):
    stock_name = "permno"
    date_name = "eom"
    meta_names = [
        "crsp_exchcd",
        "crsp_shrcd",
        "ret_exc_lead1m",
        "me",
        "me_company",
        "market_equity",
    ]

    # 1. Read benchmarks
    ret_type = "ret_vw_cap"
    benchmarks_df = load_pivot_csv(
        values=ret_type,
        index="eom",
        columns="characteristic",
        sep=",",
        filename=benchmarks_path,
    )
    benchmarks_df.index = pd.to_datetime(
        benchmarks_df.index, format="%Y-%m-%d", errors="coerce"
    )
    benchmarks_df.index.name = DATE_NAME
    for bench in benchmarks_df.columns:
        df = benchmarks_df[[bench]].dropna().astype(float)
        col = bench + "_" + ret_type
        df.columns = [col]
        Panel(df).save(col)
    # return benchmarks_df
    keep = benchmarks_df.columns.to_list() + meta_names

    # 2. Read definitions
    df = pd.read_csv(definitions_path, sep="\t", header=0, index_col=0)["Description"]
    df = df[df.index.isin(keep)]
    rag = RAG(CHARACTERISTICS_RAG, out_dir=RAG_PATH).load()
    rag.add_documents(df + " (Source: JKP)", overwrite=True)

    df = df.drop(index=meta_names, errors="ignore")
    bench_df = "JKP factor benchmark returns for `" + df.index + "`: " + df
    rag = RAG(BENCHMARKS_RAG, out_dir=RAG_PATH).load()
    rag.add_documents(bench_df, overwrite=True)

    if not build_characteristics:
        return keep
    # 3. Read characteristics from multiple files

    for seq, filename in tqdm(
        enumerate(sorted(Path(data_folder).glob("*.txt.gz"), reverse=True))
    ):
        df_data = pd.read_csv(filename, sep="\t", header=0, low_memory=False)
        if not keep:
            keep = list(set(df_data.columns) - {stock_name, date_name})
        df_data = df_data.dropna(subset=[stock_name, date_name]).convert_dtypes()
        df_data[stock_name] = pd.to_numeric(
            df_data[stock_name], errors="coerce"
        ).astype(int)
        df_data[date_name] = pd.to_datetime(
            df_data[date_name], format="%Y-%m-%d"
        ) + pd.offsets.MonthEnd(0)
        df_data.set_index([date_name, stock_name], inplace=True)
        df_data.index.names = (DATE_NAME, STOCK_NAME)

        for i, col in tqdm(
            enumerate(keep), total=len(keep), desc=f"Loading {str(filename)}"
        ):
            if col not in df_data.columns:
                logging.info(f"  - Skipping {col} as not in data")
                continue

            # Initialize or load existing panel
            if not seq:
                panel = Panel().load(
                    col, start_date="1900-01-01", end_date="2100-12-31"
                )
            else:
                panel = Panel()
            logging.info(f"{panel.name=}, {len(panel)=}, {panel.nlevels=}")

            # Append new data
            new_panel = Panel(df_data[[col]].dropna())
            panel = panel.append(new_panel)
            logging.info(f"  - append: {panel.name=}, {len(panel)=}, {panel.nlevels=}")
            panel.save(col)
            logging.info(pformat(panel.info))
    return keep


