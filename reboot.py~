    if aged:
        for i, col in tqdm(enumerate(keep), total=len(keep)):
            panel = Panel().load(col, start_date="1900-01-01", end_date="2100-12-31")
            age = panel.trend(cumcount, resample=False)  # observation age
            panel = panel.where(mask=(age >= aged)).save(col)
            logging.debug(
                f"  - aged{aged}: {panel.name=}, {len(panel)=}, {panel.nlevels=}"
            )
    return keep


