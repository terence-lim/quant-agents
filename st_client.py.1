# Initialize conversation history in session state
if "messages" not in st.session_state:
    st.session_state.messages = []

# Sidebar Controls
with st.sidebar:
    st.title("Controls")
    
    if st.session_state.messages:
        # Undo Button logic
        if st.button("Undo Last Query", use_container_width=True):
            # Find the index of the last message where role == "user"
            last_user_index = -1
            for i in range(len(st.session_state.messages) - 1, -1, -1):
                if st.session_state.messages[i]["role"] == "user":
                    last_user_index = i
                    break
            
            if last_user_index != -1:
                # Remove everything from the last user prompt onwards
                st.session_state.messages = st.session_state.messages[:last_user_index]
                st.rerun()

        # Clear Chat Button logic
        if st.button("Clear All History", use_container_width=True):
            st.session_state.messages = []
            st.rerun()
    else:
        st.write("No history to manage.")    

# Display past messages
